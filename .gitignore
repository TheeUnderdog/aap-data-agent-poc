# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Fabric provisioning secrets (generated by scripts/setup-workspace.ps1)
scripts/.env.fabric

__pycache__/

# Azure Functions local settings (contains connection strings)
api/local.settings.json
api/.python_packages/
api/.venv/
