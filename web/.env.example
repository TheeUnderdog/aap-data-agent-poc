# Entra ID App Registration (required for Docker/production)
# Used for user login (auth code flow) and Fabric API access (client_credentials).
# The service principal (CLIENT_ID) must be added as a Contributor/Member
# in the Fabric workspace by a workspace admin.
ENTRA_CLIENT_ID=your-client-id-here
ENTRA_CLIENT_SECRET=your-client-secret-here
ENTRA_TENANT_ID=16b3c013-d300-468d-ac64-7eda0820b6d3

# Fabric workspace
FABRIC_WORKSPACE_ID=e7f4acfe-90d7-4685-864a-b5f1216fe614
FABRIC_API_BASE=https://api.fabric.microsoft.com/v1

# Flask session secret (auto-generated if omitted)
# SESSION_SECRET=some-random-string
