# Fabric workspace
FABRIC_WORKSPACE_ID=your-workspace-guid-here
FABRIC_API_BASE=https://api.fabric.microsoft.com/v1

# Azure OpenAI — LLM routing (optional, for semantic question routing)
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/openai/deployments/<deployment>/chat/completions?api-version=2024-02-15-preview
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_TENANT_ID=your-tenant-id-if-cross-tenant
